---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Loader from '../components/Loader.astro';
import Transition from '../components/Transition.astro';
import Hero from '../components/Hero.astro';
import StrategicPositioning from '../components/StrategicPositioning.astro';
import KeyAdvantages from '../components/KeyAdvantages.astro';
import WhatNGSProvides from '../components/WhatNGSProvides.astro';
import CoreServiceStructure from '../components/CoreServiceStructure.astro';
import TargetClientProfile from '../components/TargetClientProfile.astro';
import FinalCTA from '../components/FinalCTA.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Nexaru Global Services — UAE Migration & Investment">
  <Loader />
  <Nav />

  <div class="scroll-container">
    <!-- 0: Hero -->
    <Hero />

    <!-- 1: Strategic Positioning -->
    <StrategicPositioning />

    <!-- 2: Transition S-002 -->
    <Transition id="trans-04" video="https://pub-1177376bfc1641b2aeba0cd63a27cb3a.r2.dev/videos/S-002.mp4" index={2} />

    <!-- 3: Transition S-003 (1) → leads into "Why global founders, investors" -->
    <Transition id="trans-05" video="https://pub-1177376bfc1641b2aeba0cd63a27cb3a.r2.dev/videos/S-003%20(1).mp4" index={3} />

    <!-- 4: Key Advantages — "Why global founders, investors" -->
    <KeyAdvantages />

    <!-- 4: What NGS Provides -->
    <WhatNGSProvides />

    <!-- 5: Core Service Structure -->
    <CoreServiceStructure />

    <!-- 6: Target Client Profile — "Designed for individuals and organizations" -->
    <TargetClientProfile />

    <!-- 7: Transition S-008 (no text) → leads into Final CTA -->
    <Transition id="trans-09" video="https://pub-1177376bfc1641b2aeba0cd63a27cb3a.r2.dev/videos/S-008.mp4" index={7} />

    <!-- 8: Final CTA — "Establish your future" -->
    <FinalCTA />
  </div>

  <WhatsAppButton />
  <script src="../scripts/main.js"></script>
</Layout>
