---
const services = [
  {
    short: 'Nexaru Global Services provides structured support...',
    full: 'Nexaru Global Services provides structured support to individuals and companies establishing their presence in the United Arab Emirates. Our approach focuses on clarity, compliance, and long-term operational alignment.',
    icon: '/icons/hands-helping.png',
  },
  {
    short: 'We coordinate every stage of the process...',
    full: 'We coordinate every stage of the process, ensuring your personal residency, corporate structure, and regulatory status are properly established and aligned with UAE legal requirements.',
    icon: '/icons/justice-hammer.png',
  },
  {
    short: 'Our role extends beyond processing...',
    full: 'Our role extends beyond processing. We provide structured guidance, continuity, and professional oversight throughout your transition.',
    icon: '/icons/guide-board.png',
  },
];
const cdn = import.meta.env.PUBLIC_CDN_URL || '';
---

<section class="section" id="section-provides" data-section="provides" data-video={`${cdn}/videos/Secuencia 006.mp4`}>
  <video class="section__video" muted playsinline preload="none"></video>

  <div class="wp-gradient-top"></div>
  <div class="gradient-bottom"></div>

  <div class="section__content wp-layout">
    <div class="wp-header">
      <h2 class="wp-headline anim-fade-up">
        Institutional support
      </h2>
      <p class="wp-subheadline anim-fade-up">
        for your migration and establishment
      </p>
    </div>

    <div class="wp-cards">
      {services.map((item, i) => (
        <div class="wp-card anim-scale-in" style={`--delay: ${i * 0.1}s`}>
          <div class="wp-card-icon">
            <img src={item.icon} alt="" class="wp-card-icon-img" />
          </div>
          <div class="wp-card-body">
            <p class="wp-card-short">{item.short}</p>
            <p class="wp-card-full">{item.full}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="wp-cta anim-fade-up">
      <button class="cta-btn cta-btn--lg">
        Request a Private Consultation
      </button>
    </div>
  </div>
</section>

<style is:global>
  #section-provides .gradient-bottom {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .wp-gradient-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 51.67%;
    background: linear-gradient(
      to bottom,
      rgb(8, 29, 37) 0%,
      rgba(8, 29, 37, 0.5) 37.8%,
      rgba(8, 29, 37, 0) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .wp-layout {
    align-items: center;
    justify-content: center;
    gap: 2.5vh;
    padding: 0 5%;
  }

  .wp-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
  }

  .wp-headline {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-extrabold);
    font-size: clamp(24px, 3.646vw, 70px);
    color: #e4e4e4;
    text-transform: uppercase;
    line-height: 1.05;
  }

  .wp-subheadline {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-regular);
    font-size: clamp(16px, 2.083vw, 40px);
    color: #e4e4e4;
    line-height: 1.2;
    font-style: italic;
  }

  .wp-cards {
    display: flex;
    gap: clamp(12px, 1.56vw, 30px);
    justify-content: center;
    flex-wrap: wrap;
  }

  .wp-card {
    display: flex;
    align-items: center;
    gap: clamp(12px, 1.48vw, 28px);
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(7.75px);
    -webkit-backdrop-filter: blur(7.75px);
    border-radius: clamp(16px, 1.23vw, 24px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: clamp(14px, 1.23vw, 24px) clamp(16px, 1.85vw, 36px);
    width: clamp(280px, 25.95vw, 498px);
    height: clamp(100px, 9vw, 160px);
    text-align: left;
    position: relative;
    overflow: hidden;
    transition:
      height 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      background 0.4s ease,
      border-color 0.4s ease,
      box-shadow 0.5s ease,
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .wp-card:hover {
    height: clamp(140px, 14vw, 260px);
    background: rgba(0, 0, 0, 0.52);
    border-color: rgba(180, 220, 240, 0.2);
    box-shadow:
      0 10px 36px rgba(0, 0, 0, 0.35),
      0 0 50px rgba(80, 180, 220, 0.06);
    transform: translateY(-2px);
  }

  .wp-card-icon {
    width: clamp(50px, 5.5vw, 100px);
    height: clamp(50px, 5.5vw, 100px);
    min-width: 50px;
    min-height: 50px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 0.4s ease;
  }

  .wp-card:hover .wp-card-icon {
    transform: scale(0.9);
    filter: drop-shadow(0 0 10px rgba(180, 220, 240, 0.18));
  }

  .wp-card-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .wp-card-body {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .wp-card-short {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-medium);
    font-size: clamp(13px, 1.46vw, 28px);
    color: #e4e4e4;
    line-height: 1.3;
    margin: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .wp-card-full {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-medium);
    font-size: clamp(11px, 1vw, 18px);
    color: #e4e4e4;
    line-height: 1.35;
    margin: 0;
    margin-top: 0;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                opacity 0.35s ease 0.08s,
                margin-top 0.45s ease;
  }

  .wp-card:hover .wp-card-short {
    opacity: 0;
    height: 0;
    overflow: hidden;
    transform: translateY(-6px);
  }

  .wp-card:hover .wp-card-full {
    max-height: 200px;
    opacity: 1;
    margin-top: 0;
  }

  /* ---- CTA ---- */
  .wp-cta {
    margin-top: 1vh;
  }

  .wp-cta .cta-btn--lg.cta-btn {
    padding: 18px 50px;
    font-size: 1rem;
    border-radius: 16px;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1440px) {
    .wp-layout { gap: 2vh; }
    .wp-card {
      width: clamp(260px, 30vw, 460px);
      height: clamp(90px, 9vw, 150px);
    }
    .wp-card:hover {
      height: clamp(130px, 14vw, 240px);
    }
    .wp-card-icon {
      width: clamp(50px, 7vw, 120px);
      height: clamp(50px, 7vw, 120px);
    }
  }

  @media (max-width: 1280px) {
    .wp-layout { gap: 1.8vh; }
    .wp-card {
      width: clamp(240px, 32vw, 420px);
      height: clamp(85px, 8.5vw, 140px);
      padding: clamp(12px, 1vw, 20px) clamp(14px, 1.5vw, 28px);
    }
    .wp-card:hover {
      height: clamp(120px, 13vw, 220px);
    }
    .wp-card-icon {
      width: clamp(48px, 6vw, 100px);
      height: clamp(48px, 6vw, 100px);
    }
    .wp-card-short { font-size: clamp(12px, 1.3vw, 22px); }
    .wp-card-full { font-size: clamp(11px, 1vw, 18px); }
    .wp-cta .cta-btn--lg.cta-btn {
      padding: 16px 40px;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 1024px) {
    .wp-layout { gap: 1.5vh; padding: 0 4%; }
    .wp-cards { gap: 12px; }
    .wp-card {
      width: 44vw;
      height: auto;
      padding: 12px 16px;
    }
    .wp-card:hover {
      height: auto;
    }
    .wp-card-icon {
      width: 60px;
      height: 60px;
      min-width: 60px;
      min-height: 60px;
    }
    .wp-card-short { font-size: clamp(12px, 1.5vw, 20px); }
    .wp-card-full { font-size: clamp(11px, 1.3vw, 16px); }
    .wp-cta .cta-btn--lg.cta-btn {
      padding: 14px 36px;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 768px) {
    .wp-gradient-top { height: 100%; }
    .wp-layout {
      padding: 0 20px;
      gap: 16px;
    }
    .wp-headline { font-size: 28px; }
    .wp-subheadline { font-size: 18px; }
    .wp-cards {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    .wp-card {
      width: 100%;
      padding: 14px 18px;
      gap: 14px;
      height: auto;
    }
    .wp-card:hover {
      height: auto;
    }
    .wp-card-icon {
      width: 56px;
      height: 56px;
      min-width: 56px;
      min-height: 56px;
    }
    .wp-card-short { font-size: 14px; }
    .wp-card-full { font-size: 13px; }
    .wp-cta .cta-btn--lg.cta-btn {
      padding: 16px 32px;
      font-size: 14px;
    }
  }

  @media (max-width: 480px) {
    .wp-layout {
      padding: 0 12px;
      gap: 12px;
    }
    .wp-headline { font-size: 22px; }
    .wp-subheadline { font-size: 15px; }
    .wp-card {
      padding: 12px 14px;
      gap: 12px;
    }
    .wp-card-icon {
      width: 48px;
      height: 48px;
      min-width: 48px;
      min-height: 48px;
    }
    .wp-card-short { font-size: 13px; }
    .wp-card-full { font-size: 12px; }
    .wp-cta .cta-btn--lg.cta-btn {
      padding: 14px 24px;
      font-size: 13px;
    }
  }
</style>
