---
const services = [
  { text: 'Nexaru Global Services provides structured support...', icon: '/icons/hands-helping.png' },
  { text: 'We coordinate every stage of the process...', icon: '/icons/justice-hammer.png' },
  { text: 'Our role extends beyond processing...', icon: '/icons/guide-board.png' },
];
const cdn = import.meta.env.PUBLIC_CDN_URL || '';
---

<section class="section" id="section-provides" data-section="provides" data-video={`${cdn}/videos/Secuencia 006.mp4`}>
  <video class="section__video" muted playsinline preload="none"></video>

  <div class="wp-gradient-top"></div>
  <div class="gradient-bottom"></div>

  <div class="section__content wp-layout">
    <div class="wp-header">
      <h2 class="wp-headline anim-fade-up">
        Institutional support
      </h2>
      <p class="wp-subheadline anim-fade-up">
        for your migration and establishment
      </p>
    </div>

    <div class="wp-cards">
      {services.map((item, i) => (
        <div class="wp-card anim-scale-in" style={`--delay: ${i * 0.1}s`}>
          <div class="wp-card-icon">
            <img src={item.icon} alt="" class="wp-card-icon-img" />
          </div>
          <p class="wp-card-text">{item.text}</p>
        </div>
      ))}
    </div>

    <div class="wp-cta anim-fade-up">
      <button class="cta-btn cta-btn--lg">
        Request a Private Consultation
      </button>
    </div>
  </div>
</section>

<style is:global>
  /* Remove backdrop-filter flickering */
  #section-provides .gradient-bottom {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* Top gradient — from dark top to transparent */
  .wp-gradient-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 51.67%;                  /* 558/1080 */
    background: linear-gradient(
      to bottom,
      rgb(8, 29, 37) 0%,
      rgba(8, 29, 37, 0.5) 37.8%,
      rgba(8, 29, 37, 0) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* Layout — uses section__content base + overrides */
  .wp-layout {
    align-items: center;
    justify-content: center;
    gap: 2.5vh;
    padding: 0 5%;
  }

  /* Header */
  .wp-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
  }

  /* Headline — 70px at 1920, y=253 */
  .wp-headline {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-extrabold);
    font-size: clamp(24px, 3.646vw, 70px);
    color: #e4e4e4;
    text-transform: uppercase;
    line-height: 1.05;
  }

  /* Subheadline — 40px at 1920, y=338 */
  .wp-subheadline {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-regular);
    font-size: clamp(16px, 2.083vw, 40px);
    color: #e4e4e4;
    line-height: 1.2;
    font-style: italic;
  }

  /* Cards row — 3 horizontal */
  .wp-cards {
    display: flex;
    gap: clamp(12px, 1.56vw, 30px);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Card — 498×201 at 1920 */
  .wp-card {
    display: flex;
    align-items: center;
    gap: clamp(12px, 1.48vw, 28px);
    background: var(--glass-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: clamp(16px, 1.23vw, 24px);
    border: var(--glass-border);
    padding: clamp(14px, 1.23vw, 24px) clamp(16px, 1.85vw, 36px);
    width: clamp(280px, 25.95vw, 498px);
    min-height: clamp(120px, 10.46vw, 201px);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.4s ease,
                border-color 0.4s ease,
                background 0.4s ease;
    cursor: pointer;
  }

  .wp-card:hover {
    transform: translateY(-4px) scale(1.02);
    background: rgba(0, 0, 0, 0.45);
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 0 40px rgba(80, 180, 220, 0.08);
  }

  /* Card icon — 153px at 1920 */
  .wp-card-icon {
    width: clamp(60px, 7.98vw, 153px);
    height: clamp(60px, 7.98vw, 153px);
    min-width: 60px;
    min-height: 60px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wp-card-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Card text — 28px medium at 1920 */
  .wp-card-text {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-medium);
    font-size: clamp(13px, 1.46vw, 28px);
    color: #e4e4e4;
    line-height: 1.4;
  }

  /* CTA */
  .wp-cta {
    margin-top: 1vh;
  }

  .wp-cta .cta-btn--lg.cta-btn {
    padding: 18px 50px;
    font-size: 1rem;
    border-radius: 16px;
  }

  /* ---- Responsive ---- */

  /* Medium desktop: ≤1440 — 3 cards still fit, slightly smaller */
  @media (max-width: 1440px) {
    .wp-layout { gap: 2vh; }
    .wp-card {
      width: clamp(260px, 30vw, 460px);
      min-height: clamp(100px, 9vw, 170px);
    }
    .wp-card-icon {
      width: clamp(50px, 7vw, 120px);
      height: clamp(50px, 7vw, 120px);
    }
  }

  /* Small desktop: ≤1280 — cards tighter */
  @media (max-width: 1280px) {
    .wp-layout { gap: 1.8vh; }
    .wp-card {
      width: clamp(240px, 32vw, 420px);
      min-height: clamp(90px, 8.5vw, 150px);
      padding: clamp(12px, 1vw, 20px) clamp(14px, 1.5vw, 28px);
    }
    .wp-card-icon {
      width: clamp(48px, 6vw, 100px);
      height: clamp(48px, 6vw, 100px);
    }
    .wp-card-text { font-size: clamp(12px, 1.3vw, 22px); }
    .wp-cta .cta-btn--lg.cta-btn {
      padding: 16px 40px;
      font-size: 0.9rem;
    }
  }

  /* Tablet landscape: ≤1024 — 2 cards per row */
  @media (max-width: 1024px) {
    .wp-layout { gap: 1.5vh; padding: 0 4%; }
    .wp-cards { gap: 12px; }
    .wp-card {
      width: 44vw;
      min-height: auto;
      padding: 12px 16px;
    }
    .wp-card-icon {
      width: 60px;
      height: 60px;
      min-width: 60px;
      min-height: 60px;
    }
    .wp-card-text { font-size: clamp(12px, 1.5vw, 20px); }
    .wp-cta .cta-btn--lg.cta-btn {
      padding: 14px 36px;
      font-size: 0.85rem;
    }
  }

  /* Tablet portrait: ≤768px — cards stack vertically */
  @media (max-width: 768px) {
    .wp-gradient-top { height: 100%; }
    .wp-layout {
      padding: 0 20px;
      gap: 16px;
    }
    .wp-headline { font-size: 28px; }
    .wp-subheadline { font-size: 18px; }
    .wp-cards {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    .wp-card {
      width: 100%;
      padding: 14px 18px;
      gap: 14px;
      min-height: auto;
    }
    .wp-card-icon {
      width: 56px;
      height: 56px;
      min-width: 56px;
      min-height: 56px;
    }
    .wp-card-text { font-size: 14px; }
    .wp-cta .cta-btn--lg.cta-btn {
      padding: 16px 32px;
      font-size: 14px;
    }
  }

  /* Mobile: ≤480px */
  @media (max-width: 480px) {
    .wp-layout {
      padding: 0 12px;
      gap: 12px;
    }
    .wp-headline { font-size: 22px; }
    .wp-subheadline { font-size: 15px; }
    .wp-card {
      padding: 12px 14px;
      gap: 12px;
    }
    .wp-card-icon {
      width: 48px;
      height: 48px;
      min-width: 48px;
      min-height: 48px;
    }
    .wp-card-text { font-size: 13px; }
    .wp-cta .cta-btn--lg.cta-btn {
      padding: 14px 24px;
      font-size: 13px;
    }
  }
</style>
