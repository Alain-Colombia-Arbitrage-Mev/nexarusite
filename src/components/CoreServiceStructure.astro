---
const coreServices = [
  { title: 'Corporate Establishment', desc: 'Structured formation of UAE companies aligned with your operational and strategic objectives', icon: '/icons/target-corporate.png' },
  { title: 'Residency and Legal Alignment', desc: 'Professional coordination of residency pathways and legal presence.', icon: '/icons/justice-residency.png' },
  { title: 'Investor and Founder Migration', desc: 'Support for entrepreneurs, investors, and founders establishing operational base in UAE.', icon: '/icons/money-investor.png' },
  { title: 'Institutional and Regulatory Coordination', desc: 'Direct management of regulatory processes and compliance requirements.', icon: '/icons/documents-regulatory.png' },
];
const cdn = import.meta.env.PUBLIC_CDN_URL || '';
---

<section class="section" id="section-services" data-section="services" data-video={`${cdn}/videos/Secuencia 007.mp4`}>
  <video class="section__video" muted playsinline preload="none"></video>

  <div class="cs-gradient-left"></div>
  <div class="gradient-top"></div>
  <div class="gradient-bottom"></div>

  <div class="section__content cs-layout">
    <div class="cs-header">
      <h2 class="cs-headline anim-fade-left">
        Complete alignment
      </h2>
      <p class="cs-subheadline anim-fade-left">
        across your personal and corporate presence
      </p>
    </div>

    <div class="cs-grid">
      {coreServices.map((item, i) => (
        <div class="cs-card anim-scale-in" style={`--delay: ${i * 0.1}s`}>
          <div class="cs-card-icon">
            <img src={item.icon} alt="" class="cs-card-icon-img" />
          </div>
          <p class="cs-card-title">{item.title}</p>
          <p class="cs-card-desc">{item.desc}</p>
        </div>
      ))}
    </div>

    <div class="cs-cta anim-fade-up">
      <button class="cta-btn cta-btn--lg">
        Begin Your Process
      </button>
    </div>
  </div>
</section>

<style is:global>
  /* Remove backdrop-filter flickering */
  #section-services .gradient-top,
  #section-services .gradient-bottom {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* Left gradient — from Pencil: 1403px wide */
  .cs-gradient-left {
    position: absolute;
    top: 0;
    left: 0;
    width: 73.07%;                   /* 1403/1920 */
    height: 100%;
    background: linear-gradient(
      to right,
      rgb(8, 29, 37) 0%,
      rgba(8, 29, 37, 0.5) 37.8%,
      rgba(8, 29, 37, 0) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* Layout — left-aligned, vertically centered */
  #section-services .cs-layout {
    justify-content: center;
    gap: 2vh;
    padding: 0 0 0 8.23% !important; /* left=158/1920 */
  }

  /* Header */
  #section-services .cs-header {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Headline — from Pencil */
  #section-services .cs-headline {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-extrabold);
    font-size: clamp(24px, 3.646vw, 70px);
    color: #e4e4e4;
    line-height: 1.02;
  }

  /* Subheadline — italic */
  #section-services .cs-subheadline {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-regular);
    font-size: clamp(16px, 2.083vw, 40px);
    color: #e4e4e4;
    font-style: italic;
    line-height: 1.2;
  }

  /* Card grid — 4 in a row */
  #section-services .cs-grid {
    display: flex !important;
    gap: clamp(8px, 0.64vw, 12px);
    flex-wrap: wrap;
  }

  /* Card — 364×275 at 1920 */
  #section-services .cs-card {
    display: flex !important;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--glass-bg);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: clamp(12px, 0.85vw, 16px);
    border: var(--glass-border);
    padding: clamp(16px, 1.56vw, 30px) clamp(14px, 1.3vw, 25px);
    width: clamp(160px, 18.96vw, 364px);
    min-height: clamp(180px, 14.32vw, 275px);
    gap: clamp(6px, 0.52vw, 10px);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.4s ease,
                border-color 0.4s ease,
                background 0.4s ease;
    cursor: pointer;
  }

  #section-services .cs-card:hover {
    transform: translateY(-4px) scale(1.02);
    background: rgba(0, 0, 0, 0.45);
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 0 40px rgba(80, 180, 220, 0.08);
  }

  /* Card icon — 77px at 1920 */
  #section-services .cs-card-icon {
    width: clamp(48px, 4.03vw, 77px);
    height: clamp(48px, 4.03vw, 77px);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: clamp(4px, 0.4vw, 8px);
  }

  #section-services .cs-card-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Card title — 20px semibold */
  #section-services .cs-card-title {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-semibold);
    font-size: clamp(13px, 1.04vw, 20px);
    color: #ededed;
    transition: color 0.4s ease;
  }

  #section-services .cs-card:hover .cs-card-title {
    color: #ffffff;
  }

  /* Card desc — 15px regular */
  #section-services .cs-card-desc {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-regular);
    font-size: clamp(11px, 0.78vw, 15px);
    color: #ededed;
    line-height: 1.4;
  }

  /* CTA — bottom right from Pencil */
  #section-services .cs-cta {
    position: absolute;
    bottom: 10%;
    right: 10%;
    z-index: 3;
  }

  #section-services .cs-cta .cta-btn--lg.cta-btn {
    padding: 18px 50px;
    font-size: 1rem;
    border-radius: 16px;
  }

  /* ---- Responsive ---- */

  /* ≤1440 */
  @media (max-width: 1440px) {
    #section-services .cs-card {
      width: clamp(160px, 22vw, 340px);
      min-height: clamp(160px, 13vw, 250px);
    }
  }

  /* ≤1280 */
  @media (max-width: 1280px) {
    #section-services .cs-layout { padding: 0 0 0 5% !important; }
    #section-services .cs-card {
      width: clamp(150px, 23vw, 300px);
      min-height: clamp(150px, 12.5vw, 230px);
    }
    #section-services .cs-cta { right: 5%; bottom: 8%; }
    #section-services .cs-cta .cta-btn--lg.cta-btn {
      padding: 16px 40px;
      font-size: 0.9rem;
    }
  }

  /* ≤1024 — 2x2 grid */
  @media (max-width: 1024px) {
    #section-services .cs-layout {
      padding: 80px 5% 40px !important;
      align-items: center;
      justify-content: flex-start;
    }
    #section-services .cs-grid {
      max-width: 90vw;
      justify-content: center;
    }
    #section-services .cs-card {
      width: 42vw;
      min-height: auto;
    }
    #section-services .cs-cta {
      position: static;
      align-self: center;
    }
  }

  /* ≤768 — single column */
  @media (max-width: 768px) {
    #section-services .cs-gradient-left { width: 100%; }
    #section-services .cs-layout {
      padding: 80px 20px 40px !important;
      gap: 12px;
      justify-content: flex-start;
    }
    #section-services .cs-headline { font-size: 28px; }
    #section-services .cs-subheadline { font-size: 18px; }
    #section-services .cs-header { align-items: center; text-align: center; }
    #section-services .cs-grid {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    #section-services .cs-card {
      width: 100%;
      min-height: auto;
      padding: 16px;
    }
    #section-services .cs-card-icon { width: 56px; height: 56px; }
    #section-services .cs-card-title { font-size: 16px; }
    #section-services .cs-card-desc { font-size: 13px; }
    #section-services .cs-cta .cta-btn--lg.cta-btn {
      padding: 16px 32px;
      font-size: 14px;
    }
  }

  /* ≤480 */
  @media (max-width: 480px) {
    #section-services .cs-layout { padding: 70px 12px 30px !important; gap: 8px; }
    #section-services .cs-headline { font-size: 20px; }
    #section-services .cs-subheadline { font-size: 14px; }
    #section-services .cs-grid { gap: 8px; }
    #section-services .cs-card {
      padding: 10px 12px;
      flex-direction: row;
      align-items: center;
      text-align: left;
      gap: 12px;
    }
    #section-services .cs-card-icon { width: 40px; height: 40px; margin-bottom: 0; }
    #section-services .cs-card-title { font-size: 13px; }
    #section-services .cs-card-desc { font-size: 11px; }
    #section-services .cs-cta .cta-btn--lg.cta-btn {
      padding: 14px 24px;
      font-size: 13px;
    }
  }
</style>
