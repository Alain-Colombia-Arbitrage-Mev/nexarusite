---
const clients = [
  { text: 'Entrepreneurs establishing new companies', icon: '/icons/newbox-entrepreneur.png' },
  { text: 'International companies expanding into UAE', icon: '/icons/burj-international.png' },
  { text: 'Founders relocating operational headquarters', icon: '/icons/travel-founders.png' },
  { text: 'Professionals establishing independent presence', icon: '/icons/professional-hex.png' },
  { text: 'Investors requiring residency alignment', icon: '/icons/team-investors.png' },
  { text: 'Families relocating with structured legal support', icon: '/icons/family-restroom.png' },
];
const cdn = import.meta.env.PUBLIC_CDN_URL || '';
---

<section class="section" id="section-clients" data-section="clients" data-video={`${cdn}/videos/Secuencia 008.mp4`}>
  <video class="section__video" muted playsinline preload="none"></video>

  <div class="gradient-top"></div>
  <div class="gradient-bottom"></div>
  <div class="tcp-overlay"></div>

  <div class="section__content tcp-layout">
    <div class="tcp-text">
      <h2 class="tcp-title anim-fade-right">
        <span class="tcp-headline">Designed for individuals and organizations</span>
        <span class="tcp-subheadline">building long-term presence</span>
      </h2>

      <p class="tcp-desc anim-fade-right">
        Our services are structured for clients seeking clarity, legal certainty, and institutional-level support during their transition into the UAE.
      </p>

      <div class="tcp-pills">
        {clients.map((item, i) => (
          <div class="tcp-pill anim-scale-in" style={`--delay: ${i * 0.08}s`}>
            <div class="tcp-pill-icon">
              <img src={item.icon} alt="" class="tcp-pill-icon-img" />
            </div>
            <p class="tcp-pill-text">{item.text}</p>
          </div>
        ))}
      </div>

      <div class="tcp-cta anim-fade-up">
        <button class="cta-btn cta-btn--lg">
          Start Your Assessment
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  /* Remove backdrop-filter flickering */
  :global(#section-clients) .gradient-top,
  :global(#section-clients) .gradient-bottom {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* Right blur overlay — from Pencil: 1140px wide, right-aligned */
  :global(#section-clients) .tcp-overlay {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 55%;
    background: linear-gradient(to left, transparent 5%, rgba(8, 29, 37, 0.08) 35%, rgba(8, 29, 37, 0.18));
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 1;
    pointer-events: none;
  }

  /* Layout — right-aligned, vertically centered */
  :global(#section-clients) .tcp-layout {
    align-items: flex-end;
    justify-content: center;
    gap: 2vh;
    padding: 0 4% 0 0;
  }

  /* Text wrapper — right-aligned */
  :global(#section-clients) .tcp-text {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2vh;
    max-width: 55vw;
    text-align: right;
  }

  /* Title */
  :global(#section-clients) .tcp-title {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: #dfdfdf;
  }

  :global(#section-clients) .tcp-headline {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-extrabold);
    font-size: clamp(22px, 5vh, 56px);
    text-transform: uppercase;
    line-height: 1.05;
  }

  :global(#section-clients) .tcp-subheadline {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-regular);
    font-size: clamp(16px, 3vh, 32px);
    line-height: 1.2;
  }

  /* Description — 26px at 1920 */
  :global(#section-clients) .tcp-desc {
    font-family: var(--f-primary);
    font-size: clamp(13px, 2vh, 20px);
    color: #dfdfdf;
    line-height: 1.4;
    max-width: 41.25vw;              /* 792/1920 */
  }

  /* Pills grid — 2 columns, 3 rows */
  :global(#section-clients) .tcp-pills {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(8px, 0.63vw, 12px);
    width: 100%;
    max-width: 48vw;                 /* ~920/1920 */
  }

  /* Pill — 451×70 at 1920 */
  :global(#section-clients) .tcp-pill {
    display: flex;
    align-items: center;
    gap: clamp(8px, 0.69vw, 13px);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: clamp(12px, 0.92vw, 18px);
    border: var(--glass-border);
    padding: clamp(12px, 1.37vw, 26px) clamp(12px, 0.92vw, 18px);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.4s ease,
                border-color 0.4s ease,
                background 0.4s ease;
    cursor: pointer;
  }

  :global(#section-clients) .tcp-pill:hover {
    transform: translateY(-3px) scale(1.01);
    background: rgba(0, 0, 0, 0.55);
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow:
      0 6px 24px rgba(0, 0, 0, 0.3),
      0 0 30px rgba(80, 180, 220, 0.06);
  }

  /* Pill icon — 44px at 1920 */
  :global(#section-clients) .tcp-pill-icon {
    width: clamp(30px, 2.29vw, 44px);
    height: clamp(30px, 2.29vw, 44px);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(#section-clients) .tcp-pill-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Pill text — 14px semibold */
  :global(#section-clients) .tcp-pill-text {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-semibold);
    font-size: clamp(11px, 0.73vw, 14px);
    color: #e6e6e6;
    white-space: nowrap;
  }

  /* CTA */
  :global(#section-clients) .tcp-cta {
    margin-top: 1vh;
  }

  :global(#section-clients) .tcp-cta .cta-btn--lg.cta-btn {
    padding: 18px 50px;
    font-size: 1rem;
    border-radius: 16px;
  }

  /* ---- Responsive ---- */

  @media (max-width: 1440px) {
    :global(#section-clients) .tcp-text { max-width: 60vw; }
    :global(#section-clients) .tcp-pills { max-width: 55vw; }
  }

  @media (max-width: 1280px) {
    :global(#section-clients) .tcp-text { max-width: 65vw; }
    :global(#section-clients) .tcp-pills { max-width: 60vw; }
    :global(#section-clients) .tcp-pill-text { white-space: normal; }
    :global(#section-clients) .tcp-cta .cta-btn--lg.cta-btn {
      padding: 16px 40px;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 1024px) {
    :global(#section-clients) .tcp-layout {
      align-items: center;
      padding: 0 5%;
    }
    :global(#section-clients) .tcp-text {
      align-items: center;
      text-align: center;
      max-width: 90vw;
    }
    :global(#section-clients) .tcp-desc { max-width: 80vw; }
    :global(#section-clients) .tcp-pills { max-width: 85vw; }
    :global(#section-clients) .tcp-pill-text { white-space: normal; font-size: 13px; }
    :global(#section-clients) .tcp-cta .cta-btn--lg.cta-btn {
      padding: 14px 36px;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 768px) {
    :global(#section-clients) .tcp-overlay {
      width: 100%;
      background: rgba(8, 29, 37, 0.3);
    }
    :global(#section-clients) .tcp-layout {
      padding: 0 16px;
      gap: 12px;
    }
    :global(#section-clients) .tcp-text {
      align-items: center;
      text-align: center;
      max-width: 100%;
      gap: 12px;
    }
    :global(#section-clients) .tcp-headline { font-size: 24px; }
    :global(#section-clients) .tcp-subheadline { font-size: 16px; }
    :global(#section-clients) .tcp-desc { font-size: 14px; max-width: 100%; }
    :global(#section-clients) .tcp-pills {
      grid-template-columns: 1fr;
      max-width: 100%;
    }
    :global(#section-clients) .tcp-pill { padding: 12px 14px; }
    :global(#section-clients) .tcp-pill-icon { width: 32px; height: 32px; }
    :global(#section-clients) .tcp-pill-text { font-size: 13px; }
    :global(#section-clients) .tcp-cta .cta-btn--lg.cta-btn {
      padding: 16px 32px;
      font-size: 14px;
    }
  }

  @media (max-width: 480px) {
    :global(#section-clients) .tcp-layout { padding: 0 12px; gap: 10px; }
    :global(#section-clients) .tcp-headline { font-size: 20px; }
    :global(#section-clients) .tcp-subheadline { font-size: 14px; }
    :global(#section-clients) .tcp-desc { font-size: 13px; }
    :global(#section-clients) .tcp-pill { padding: 10px 12px; gap: 8px; }
    :global(#section-clients) .tcp-pill-icon { width: 28px; height: 28px; }
    :global(#section-clients) .tcp-pill-text { font-size: 12px; }
    :global(#section-clients) .tcp-cta .cta-btn--lg.cta-btn {
      padding: 14px 24px;
      font-size: 13px;
    }
  }
</style>
