---
const clients = [
  { text: 'Entrepreneurs establishing new companies', icon: 'N' },
  { text: 'International companies expanding into UAE', icon: 'B' },
  { text: 'Founders relocating operational headquarters', icon: 'T' },
  { text: 'Professionals establishing independent presence', icon: 'P' },
  { text: 'Investors requiring residency alignment', icon: 'I' },
  { text: 'Families relocating with structured legal support', icon: 'F' },
];
---

<section class="section" id="section-clients" data-section="clients" data-video="/videos/Secuencia 008.mp4">
  <video class="section__video" muted playsinline preload="none"></video>

  <div class="gradient-top"></div>
  <div class="gradient-bottom"></div>

  <!-- Right blur overlay -->
  <div class="tcp__overlay"></div>

  <div class="tcp__content section__content">
    <div class="tcp__text">
      <h2 class="tcp__title anim-fade-right">
        <span class="text-headline">Designed for individuals and organizations</span>
        <span class="text-subheadline">building long-term presence</span>
      </h2>

      <p class="tcp__desc anim-fade-right">
        Our services are structured for clients seeking clarity, legal certainty, and institutional-level support during their transition into the UAE.
      </p>

      <div class="tcp__pills">
        {clients.map((item, i) => (
          <div class="client-pill anim-scale-in" style={`--delay: ${i * 0.08}s`}>
            <div class="client-pill__icon">
              <div class="section-icon__placeholder" style="font-size:1.4rem;width:44px;height:44px;display:flex;align-items:center;justify-content:center">{item.icon}</div>
            </div>
            <p class="client-pill__text">{item.text}</p>
          </div>
        ))}
      </div>

      <div class="tcp__cta anim-fade-up">
        <button class="cta-btn--lg cta-btn">
          Start Your Assessment
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .tcp__overlay {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 60%;
    background: linear-gradient(to left, transparent, rgba(8, 29, 37, 0.2) 38%, rgba(8, 29, 37, 0.4));
    backdrop-filter: blur(33px);
    -webkit-backdrop-filter: blur(33px);
    z-index: 1;
    pointer-events: none;
  }

  .tcp__content {
    align-items: flex-end;
    padding: 120px 4% 100px;
  }

  .tcp__text {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 20px;
    max-width: 1000px;
    text-align: right;
  }

  .tcp__title {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: #dfdfdf;
  }

  .tcp__desc {
    font-size: 1.6rem;
    color: #dfdfdf;
    line-height: 1.4;
    max-width: 790px;
  }

  .tcp__pills {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;
    max-width: 920px;
  }

  .tcp__cta {
    margin-top: 20px;
  }
</style>
