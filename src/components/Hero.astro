    icon: `<svg width="38" height="38" viewBox="0 0 38 38" fill="none"><path d="M24.5 14.78l6.65-4.16L19.52 3.35c-.5-.31-1.15-.31-1.65 0L6.23 10.62l6.65 4.16c1.26-1.87 3.4-3.1 5.81-3.1 2.41 0 4.55 1.23 5.81 3.1zM25.7 18.69c0 3.33-2.34 6.1-5.45 6.82v8.07l11.73-7.34c.45-.28.73-.78.73-1.32V13.32l-7.1 4.44c.05.31.09.61.09.93zM11.68 18.69c0-.31.05-.62.09-.93l-7.1-4.44v11.6c0 .53.28 1.04.73 1.32l11.73 7.34v-8.07c-3.12-.72-5.45-3.49-5.45-6.82z" fill="#D5D5D5"/></svg>`,
