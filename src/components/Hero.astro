---

<section class="section" id="section-hero" data-section="hero" data-video="/videos/Secuencia 001.mp4">
  <video class="section__video" muted playsinline preload="auto"></video>

  <div class="hero__glass-top"></div>
  <div class="hero__glass-bottom"></div>
  <div class="hero__vignette-left"></div>

  <!-- Left text block -->
  <div class="hero__left">
    <div class="hero__card">
      <p class="hero__pretitle anim-fade-left">Looking to migrate or invest in the</p>
      <div class="hero__title">
        <span class="hero__title-line1 anim-fade-left">United Arab</span>
        <span class="hero__title-line2 anim-fade-left">Emirates?</span>
      </div>
      <p class="hero__subtitle anim-fade-left">
        Discover the world's most stable, secure, and globally connected environment to build your personal and corporate future.
      </p>
      <p class="hero__body anim-fade-left">
        The UAE offers strong legal stability, tax advantages, and global access. Nexaru Global Services provides expert support for individuals and businesses to confidently establish their legal presence.
      </p>
    </div>
  </div>

  <!-- Right side icons — perfect circular arc using calc(vw - vh) for responsive scaling -->
  <div class="hero__right">
    {sideIcons.map((item, i) => {
      // Perfect circle: center=26vw from right, 50vh. Radius=32vh
      // 6 points at angles: -70°, -42°, -14°, +14°, +42°, +70°
      // Arc: center from right edge, radius in vh
      // min() ensures labels always fit: at 1920px uses 26vw (499px),
      // at narrower screens caps center so middle icons stay ≥200px from right edge
      const arcs = [
        { right: 'calc(min(30vw, 100vw - 480px) - 10.9vh)', top: '19.9vh' },   // -70° Strategic
        { right: 'calc(min(30vw, 100vw - 480px) - 23.8vh)', top: '28.6vh' },   // -42° Key Advantages
        { right: 'calc(min(30vw, 100vw - 480px) - 31.0vh)', top: '42.3vh' },   // -14° NGS Provides
        { right: 'calc(min(30vw, 100vw - 480px) - 31.0vh)', top: '57.7vh' },   // +14° Core Service
        { right: 'calc(min(30vw, 100vw - 480px) - 23.8vh)', top: '71.4vh' },   // +42° Target Client
        { right: 'calc(min(30vw, 100vw - 480px) - 10.9vh)', top: '80.1vh' },   // +70° Establish
      ];
      const pos = arcs[i];
      return (
        <button class="hero__icon anim-fade-right" data-target={item.target} style={`--delay: ${i * 0.1}s; right: ${pos.right}; top: ${pos.top}`}>
          <div class="hero__icon-circle">
            <Fragment set:html={item.icon} />
          </div>
          <div class="hero__icon-label">
            {item.label.map(line => <span>{line}</span>)}
          </div>
        </button>
      );
    })}
  </div>

  <!-- CTA bottom center -->
  <div class="hero__cta anim-fade-up">
    <button class="hero__cta-btn">
      Start Your Migration or Investment Assessment
    </button>
  </div>
</section>

<style>
  /* Rectangle 7 — glass top (Figma 848:275) */
  .hero__glass-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 18.7%;    /* 202/1080 — scales with section */
    background: linear-gradient(
      to bottom,
      rgba(4, 15, 19, 0.5) 0%,
      rgba(4, 15, 19, 0.2) 58.65%,
      rgba(4, 15, 19, 0) 93.75%
    );
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 2;
    pointer-events: none;
  }

  /* Rectangle 6 — glass bottom (Figma 848:274) */
  .hero__glass-bottom {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 23.8%;    /* 257/1080 */
    background: linear-gradient(
      to top,
      rgba(4, 15, 19, 0.7) 0%,
      rgba(4, 15, 19, 0) 100%
    );
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 2;
    pointer-events: none;
  }

  /* Left vignette — darkens globe behind text area */
  .hero__vignette-left {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(
      ellipse 60% 70% at 20% 50%,
      rgba(2, 8, 12, 0.35) 0%,
      rgba(2, 8, 12, 0.15) 40%,
      transparent 65%
    );
  }

  /* ---- Left text block (Figma: 1920×1080) ---- */
  .hero__left {
    position: absolute;
    left: 5.47%;      /* 105/1920 */
    top: 22%;
    z-index: 3;
    max-width: 546px;
  }

  .hero__card {
    background: rgba(4, 15, 19, 0.45);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 20px;
    padding: 36px 40px;
  }

  .hero__pretitle {
    font-weight: var(--f-weight-semibold);
    font-size: 28.12px;
    color: #e3e3e3;
    line-height: 1.2;
    margin-bottom: 0;
  }

  .hero__title {
    display: flex;
    flex-direction: column;
    margin-top: 4px;
    margin-bottom: 24px;
  }

  .hero__title-line1 {
    font-weight: var(--f-weight-extrabold);
    font-size: 68.54px;
    color: #e3e3e3;
    line-height: 84.36px;
    text-transform: uppercase;
  }

  .hero__title-line2 {
    font-weight: var(--f-weight-black);
    font-size: 84.36px;
    color: #e3e3e3;
    line-height: 84.36px;
    text-transform: uppercase;
  }

  .hero__subtitle {
    font-weight: var(--f-weight-regular);
    font-size: 26.36px;
    color: #e3e3e3;
    line-height: 1.25;
    max-width: 479px;
    margin-bottom: 24px;
  }

  .hero__body {
    font-weight: var(--f-weight-regular);
    font-size: 17.58px;
    color: #e3e3e3;
    line-height: 1.35;
    max-width: 546px;
  }

  /* ---- Right icons — absolute arc around globe ---- */
  .hero__right {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }

  .hero__icon {
    position: absolute;
    display: flex;
    align-items: center;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    pointer-events: auto;
    /* Width = only the circle, label is absolutely positioned outside */
    width: clamp(50px, 3.9vw, 75px);
    height: clamp(50px, 3.9vw, 75px);
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 0.35s ease;
  }

  .hero__icon:hover {
    transform: translateX(-10px) scale(1.06);
    filter: brightness(1.2);
  }

  .hero__icon:hover .hero__icon-label {
    color: #ffffff;
    text-shadow: 0 0 12px rgba(180, 220, 240, 0.3);
  }

  .hero__icon-circle {
    width: clamp(50px, 3.9vw, 75px);
    height: clamp(50px, 3.9vw, 75px);
    border-radius: 50%;
    border: 2.24px solid #d5d5d5;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: border-color 0.35s ease, background 0.35s ease,
                box-shadow 0.35s ease, transform 0.35s ease;
  }

  .hero__icon-circle :global(svg) {
    width: clamp(24px, 1.95vw, 37px);
    height: clamp(24px, 1.95vw, 37px);
  }

  .hero__icon:hover .hero__icon-circle {
    border-color: #ffffff;
    background: rgba(20, 60, 80, 0.35);
    box-shadow: 0 0 30px rgba(80, 180, 220, 0.3);
    transform: scale(1.1);
  }

  .hero__icon-label {
    position: absolute;
    left: calc(100% + 14px);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    font-family: var(--f-primary);
    font-weight: var(--f-weight-semibold);
    font-size: clamp(12px, 0.93vw, 18px);
    color: #ffffff;
    line-height: 1.2;
    text-align: left;
    white-space: nowrap;
    text-shadow:
      0 0 8px rgba(0, 0, 0, 0.9),
      0 0 20px rgba(0, 0, 0, 0.7),
      0 1px 3px rgba(0, 0, 0, 0.8);
    transition: color 0.35s ease, text-shadow 0.35s ease;
  }

  /* ---- CTA button — always centered ---- */
  .hero__cta {
    position: absolute;
    bottom: 5%;
    left: 0;
    right: 0;
    z-index: 3;
    display: flex;
    justify-content: center;
  }

  .hero__cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    border: none;
    padding: 24px 40px;
    font-family: var(--f-primary);
    font-weight: var(--f-weight-black);
    font-size: clamp(13px, 1.04vw, 16px);
    color: white;
    text-align: center;
    white-space: nowrap;
    box-shadow: 0 0 70px rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hero__cta-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 0 100px rgba(255, 255, 255, 0.65);
  }

  /* ---- Responsive ---- */

  /* Large desktop: 1601-1920+ — base styles above handle this */

  /* Medium desktop: 1280-1600 */
  @media (max-width: 1600px) {
    .hero__left {
      left: calc(105 / 1920 * 100vw);
      top: 22%;
      max-width: 38vw;
    }
    .hero__pretitle { font-size: clamp(18px, 1.46vw, 28.12px); }
    .hero__title-line1 { font-size: clamp(38px, 3.57vw, 68.54px); line-height: 1.08; }
    .hero__title-line2 { font-size: clamp(46px, 4.39vw, 84.36px); line-height: 1.0; }
    .hero__subtitle { font-size: clamp(16px, 1.37vw, 26.36px); max-width: 36vw; }
    .hero__body { font-size: clamp(12px, 0.916vw, 17.58px); max-width: 36vw; }
    .hero__icon-label { font-size: clamp(11px, 0.82vw, 16px); }
  }

  /* Small desktop: 1024-1280 */
  @media (max-width: 1280px) {
    .hero__left {
      left: 4%;
      top: 22%;
      max-width: 42vw;
    }
    .hero__pretitle { font-size: clamp(16px, 1.4vw, 24px); }
    .hero__title-line1 { font-size: clamp(32px, 3.2vw, 54px); line-height: 1.08; }
    .hero__title-line2 { font-size: clamp(38px, 3.9vw, 66px); line-height: 1.0; }
    .hero__subtitle { font-size: clamp(14px, 1.3vw, 22px); max-width: 38vw; }
    .hero__body { font-size: clamp(11px, 0.88vw, 15px); max-width: 38vw; }
    .hero__icon-label { font-size: clamp(10px, 0.75vw, 14px); }
    .hero__icon-circle { width: clamp(44px, 3.5vw, 60px); height: clamp(44px, 3.5vw, 60px); }
    .hero__icon { width: clamp(44px, 3.5vw, 60px); height: clamp(44px, 3.5vw, 60px); }
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .hero__left { left: 5%; top: 22%; max-width: 55vw; }
    .hero__icon-label { display: none; }
    .hero__icon-circle { width: 50px; height: 50px; }
    .hero__icon { width: 50px; height: 50px; }
    .hero__icon-circle :global(svg) { width: 24px; height: 24px; }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero__left { left: 24px; right: 24px; top: 18%; max-width: calc(100vw - 48px); }
    .hero__pretitle { font-size: 16px; }
    .hero__title-line1 { font-size: 32px; line-height: 1.08; }
    .hero__title-line2 { font-size: 40px; line-height: 1.0; }
    .hero__subtitle { font-size: 15px; max-width: 100%; }
    .hero__body { font-size: 12px; max-width: 100%; }
    .hero__icon { right: 8px !important; width: 42px; height: 42px; }
    .hero__icon-circle { width: 42px; height: 42px; }
    .hero__icon-circle :global(svg) { width: 20px; height: 20px; }
    .hero__cta { bottom: 30px; }
    .hero__cta-btn { font-size: 13px; padding: 18px 20px; white-space: normal; }
  }
</style>
