---
---

<section class="section" id="section-cta" data-section="cta" data-video="/videos/Secuencia 009.mp4">
  <video class="section__video" muted playsinline preload="none"></video>

  <div class="gradient-top" style="height:491px"></div>
  <div class="gradient-bottom" style="height:428px"></div>

  <!-- Right fade -->
  <div class="fcta__right-fade"></div>

  <div class="fcta__content section__content">
    <div class="fcta__text">
      <h2 class="fcta__title anim-fade-up">
        <span class="text-headline">Establish your future</span>
        <span class="text-subheadline">from one of the world's most strategic jurisdictions</span>
      </h2>

      <p class="fcta__desc anim-fade-up">
        Whether you are relocating personally or establishing corporate operations, Nexaru Global Services ensures your transition is structured, secure, and professionally managed.
      </p>

      <p class="fcta__sub anim-fade-up">
        Begin with a structured assessment to determine the optimal pathway for your case.
      </p>
    </div>

    <div class="fcta__buttons anim-fade-up">
      <button class="cta-btn--lg cta-btn">
        Start Your Migration or Investment Process
      </button>
      <button class="cta-btn--lg cta-btn">
        Contact Nexaru Global Services
      </button>
    </div>
  </div>
</section>

<style>
  .fcta__right-fade {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 756px;
    background: linear-gradient(to left, rgba(4, 15, 19, 0.7), transparent);
    backdrop-filter: blur(var(--glass-blur));
    z-index: 1;
    pointer-events: none;
  }

  .fcta__content {
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 30px;
    padding: 120px 10%;
  }

  .fcta__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 1300px;
  }

  .fcta__title {
    display: flex;
    flex-direction: column;
    gap: 8px;
    color: #e8e8e8;
  }

  .fcta__desc {
    font-size: 1.8rem;
    color: #e8e8e8;
    line-height: 1.4;
    max-width: 1100px;
  }

  .fcta__sub {
    font-weight: var(--f-weight-semibold);
    font-size: 1.4rem;
    color: #e8e8e8;
    margin-top: 20px;
  }

  .fcta__buttons {
    display: flex;
    gap: 30px;
    margin-top: 20px;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
