---
---

<section class="section" id="section-strategic" data-section="strategic" data-video="/videos/Secuencia 003.mp4">
  <video class="section__video" muted playsinline preload="none"></video>

  <div class="gradient-left-teal"></div>
  <div class="gradient-top"></div>
  <div class="gradient-bottom"></div>

  <div class="sp__panel anim-fade-left">
    <h2 class="sp__title">
      A country built for global mobility, investment, and long-term security
    </h2>

    <div class="sp__body">
      <p>
        <strong>The United Arab Emirates</strong> offers a unique combination of legal certainty, financial infrastructure, and international connectivity. Its regulatory framework supports global entrepreneurs, investors, and professionals seeking operational stability and expansion.
      </p>
    </div>

    <div class="sp__detail">
      <p>
        <strong>With direct access to global markets,</strong> modern banking systems, and a secure legal environment, the UAE enables individuals and companies to establish a future aligned with international growth.
      </p>
      <p>
        <strong>Nexaru Global Services</strong> ensures this transition is structured, compliant, and professionally managed from initial assessment to full operational readiness.
      </p>
    </div>

    <button class="cta-btn--white cta-btn anim-fade-up">
      Explore Your Pathway
    </button>
  </div>

  <div class="sp__badge anim-fade-right">
    <div class="section-icon__circle" style="width:100px;height:100px;">
      <svg width="50" height="50" viewBox="0 0 50 50" fill="none"><path d="M11.68 9.35c1.08 0 2.14.32 3.04.93.9.6 1.6 1.46 2.01 2.46.41 1 .51 2.1.29 3.16-.22 1.06-.75 2.03-1.52 2.79h.86c.62 0 1.21.25 1.65.69.44.44.69 1.03.69 1.65s-.25 1.21-.69 1.65c-.44.44-1.03.69-1.65.69h-.58c.59 2.79 2.33 4.67 3.33 5.54.65.57 1.14 1.43 1.14 2.42 0 .39-.08.77-.22 1.13-.15.36-.37.68-.64.95-.27.27-.6.49-.96.64-.36.15-.74.22-1.13.22H6.06c-.39 0-.77-.08-1.13-.22-.36-.15-.68-.37-.95-.64-.27-.27-.49-.6-.64-.96-.15-.36-.22-.74-.22-1.13 0-.99.49-1.85 1.14-2.42 1-.88 2.74-2.75 3.33-5.54h-.58c-.62 0-1.21-.25-1.65-.69-.44-.44-.69-1.03-.69-1.65s.25-1.21.69-1.65c.44-.44 1.03-.69 1.65-.69h.86c-.77-.76-1.3-1.73-1.52-2.79-.22-1.06-.12-2.16.29-3.16.41-1 1.11-1.86 2.01-2.46.9-.6 1.96-.93 3.04-.93zM20.25 3.12c.41 0 .81.16 1.1.46.29.29.46.69.46 1.1v1.95c0 .31.12.61.34.83.22.22.52.34.83.34.31 0 .61-.12.83-.34.22-.22.34-.52.34-.83V4.68c0-.41.16-.81.46-1.1.29-.29.69-.46 1.1-.46.41 0 .81.16 1.1.46.29.29.46.69.46 1.1v1.95c0 .31.12.61.34.83.22.22.52.34.83.34.31 0 .61-.12.83-.34.22-.22.34-.52.34-.83V4.68c0-.41.16-.81.46-1.1.29-.29.69-.46 1.1-.46h.39c.31 0 .61.12.83.34.22.22.34.52.34.83v6.62c0 .83-.33 1.62-.91 2.2-.58.58-1.38.91-2.2.91h-.34c.41 8.5 3.37 13.59 4.4 15.13.37.55.62 1.22.62 1.94 0 1.76-1.42 3.18-3.18 3.18H20.7c.69-.79 1.1-1.82 1.1-2.94 0-1.52-.75-2.78-1.67-3.59-.36-.32-.7-.66-1.01-1.04 1.24-2.57 2.74-6.82 3.02-12.68h-.34c-.83 0-1.62-.33-2.2-.91-.58-.58-.91-1.38-.91-2.2V4.28c0-.31.12-.61.34-.83.22-.22.52-.34.83-.34h.39z" fill="#D5D5D5"/></svg>
    </div>
    <div class="sp__badge-label">
      <span>STRATEGIC</span>
      <span>POSITIONING</span>
    </div>
  </div>

  <!-- Decorative connector lines from badge — Figma 857:357 (vertical) + 857:356 (horizontal) -->
  <div class="sp__connector anim-fade-right">
    <!-- Vertical line down from badge -->
    <div class="sp__connector-v"></div>
    <!-- Horizontal line going right -->
    <div class="sp__connector-h"></div>
  </div>
</section>

<style>
  /* Left gradient — teal overlay matching Figma 857:346 */
  .gradient-left-teal {
    position: absolute;
    top: 0;
    left: 0;
    width: 51.25%;        /* 984/1920 */
    height: 100%;
    background: linear-gradient(
      to right,
      rgb(26, 58, 71) 0%,
      rgba(26, 58, 71, 0.5) 37.8%,
      rgba(26, 58, 71, 0) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* Glass card — Figma 857:349: left:169px, vertically centered */
  .sp__panel {
    position: absolute;
    left: 8.8%;             /* 169/1920 */
    top: 10%;
    transform: none;
    width: clamp(400px, 36.25vw, 696px);        /* 696/1920 */
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 40px 47px 36px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 18.7px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* Title — Figma 857:350: Montserrat Bold 32px */
  .sp__title {
    font-weight: var(--f-weight-bold);
    font-size: clamp(22px, 1.67vw, 32px);
    color: #e0e0e0;
    text-transform: uppercase;
    line-height: 1.25;
  }

  /* Body — Figma 857:351: ~24.6px */
  .sp__body {
    font-size: clamp(16px, 1.28vw, 24.6px);
    line-height: 1.45;
    color: #e0e0e0;
  }

  .sp__body strong {
    font-weight: var(--f-weight-bold);
  }

  /* Detail — Figma 857:352: ~15px */
  .sp__detail {
    font-size: clamp(12px, 0.78vw, 15px);
    line-height: 1.6;
    color: #e0e0e0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sp__detail strong {
    font-weight: var(--f-weight-bold);
  }

  /* White CTA — Figma 857:353 */
  .sp__panel .cta-btn--white {
    align-self: center;
    margin-top: 8px;
  }

  /* Badge — Figma 857:355: right:393px top:201px */
  .sp__badge {
    position: absolute;
    right: 20.5%;           /* 393/1920 */
    top: 18.6%;             /* 201/1080 */
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .sp__badge .section-icon__circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 3px solid #d5d5d5;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    flex-shrink: 0;
  }

  .sp__badge-label {
    display: flex;
    flex-direction: column;
    font-weight: var(--f-weight-medium);
    font-size: 1.5rem;
    color: #d5d5d5;
    white-space: nowrap;
    text-shadow:
      0 0 8px rgba(0, 0, 0, 0.9),
      0 0 20px rgba(0, 0, 0, 0.7),
      0 1px 3px rgba(0, 0, 0, 0.8);
  }

  /* Decorative connector lines — Figma 857:356 + 857:357 */
  .sp__connector {
    position: absolute;
    /* Vertical line starts below badge circle center */
    right: calc(20.5% + 50px);     /* aligned with badge circle center */
    top: calc(18.6% + 110px);      /* below badge */
    z-index: 3;
    pointer-events: none;
  }

  .sp__connector-v {
    width: 2px;
    height: 30.8vh;               /* ~333/1080 */
    background: rgba(213, 213, 213, 0.4);
    margin-left: auto;
    margin-right: auto;
  }

  .sp__connector-h {
    width: 25.8vh;                 /* ~278/1080 */
    height: 2px;
    background: rgba(213, 213, 213, 0.4);
    margin-top: -1px;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1600px) {
    .sp__panel {
      left: 6%;
      padding: 60px 40px 40px;
    }
    .sp__badge {
      right: 15%;
    }
  }

  @media (max-width: 1280px) {
    .sp__panel {
      left: 5%;
      width: clamp(360px, 42vw, 600px);
      padding: 50px 36px 36px;
      gap: 20px;
    }
    .sp__title { font-size: clamp(20px, 1.8vw, 28px); }
    .sp__body { font-size: clamp(14px, 1.4vw, 20px); }
    .sp__detail { font-size: clamp(11px, 0.9vw, 14px); }
    .sp__badge { right: 10%; }
    .sp__badge-label { font-size: 1.2rem; }
    .sp__badge .section-icon__circle { width: 80px; height: 80px; }
  }

  @media (max-width: 1024px) {
    .sp__panel {
      left: 5%;
      right: 5%;
      width: auto;
      max-width: 90vw;
      top: 50%;
    }
    .sp__badge { display: none; }
    .sp__connector { display: none; }
  }

  @media (max-width: 768px) {
    .sp__panel {
      left: 16px;
      right: 16px;
      padding: 32px 24px;
      gap: 16px;
    }
    .sp__title { font-size: 18px; }
    .sp__body { font-size: 14px; }
    .sp__detail { font-size: 12px; }
  }
</style>
