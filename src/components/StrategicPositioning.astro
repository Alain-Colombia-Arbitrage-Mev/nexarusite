---
---

<section class="section" id="section-strategic" data-section="strategic" data-video="/videos/Secuencia 003.mp4">
  <video class="section__video" muted playsinline preload="none"></video>

  <div class="gradient-left-teal"></div>
  <div class="gradient-top"></div>
  <div class="gradient-bottom"></div>

  <div class="sp__panel anim-fade-left">
    <h2 class="sp__title">
      A country built for global mobility, investment, and long-term security
    </h2>

    <div class="sp__body">
      <p>
        <strong>The United Arab Emirates</strong> offers a unique combination of legal certainty, financial infrastructure, and international connectivity. Its regulatory framework supports global entrepreneurs, investors, and professionals seeking operational stability and expansion.
      </p>
    </div>

    <div class="sp__detail">
      <p>
        <strong>With direct access to global markets,</strong> modern banking systems, and a secure legal environment, the UAE enables individuals and companies to establish a future aligned with international growth.
      </p>
      <p>
        <strong>Nexaru Global Services</strong> ensures this transition is structured, compliant, and professionally managed from initial assessment to full operational readiness.
      </p>
    </div>

    <button class="cta-btn--white cta-btn anim-fade-up">
      Explore Your Pathway
    </button>
  </div>

  <!-- Right side group: Badge + Connector + Map (single SVG) -->
  <div class="sp__right-group anim-fade-right">
    <img src="/vectormapa1920.svg" alt="" class="sp__right-svg" />
  </div>
</section>

<style>
  /* Remove backdrop-filter on gradients to prevent flickering with video */
  #section-strategic .gradient-top,
  #section-strategic .gradient-bottom {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* Left gradient — teal overlay */
  .gradient-left-teal {
    position: absolute;
    top: 0;
    left: 0;
    width: 51.25%;        /* 984/1920 */
    height: 100%;
    background: linear-gradient(
      to right,
      rgb(26, 58, 71) 0%,
      rgba(26, 58, 71, 0.5) 37.8%,
      rgba(26, 58, 71, 0) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /*
   * Glass card — reference image verified at 1920×1080:
   *   x=169, y=180, w=696
   * All units in vw so proportions scale with width only.
   */
  .sp__panel {
    position: absolute;
    left: 8.8%;                    /* 169/1920 */
    top: 16.67%;                   /* 180/1080 */
    width: 36.25vw;                /* 696/1920 */
    min-width: 360px;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 1.25vw;                   /* 24/1920 */
    padding: 3.8vw 2.45vw 2.4vw;  /* ~73, 47, 46 at 1920 */
    background: rgba(255, 255, 255, 0.1);
    border-radius: 18.7px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* Title — 32/1920 = 1.667vw */
  .sp__title {
    font-weight: var(--f-weight-bold);
    font-size: 1.667vw;
    color: #e0e0e0;
    text-transform: uppercase;
    line-height: 1.25;
  }

  /* Body — 24.6/1920 = 1.28vw */
  .sp__body {
    font-size: 1.28vw;
    line-height: 1.4;
    color: #e0e0e0;
  }

  .sp__body strong {
    font-weight: var(--f-weight-bold);
  }

  /* Detail — 15/1920 = 0.78vw */
  .sp__detail {
    font-size: 0.78vw;
    line-height: 1.55;
    color: #e0e0e0;
    display: flex;
    flex-direction: column;
    gap: 0.42vw;
  }

  .sp__detail strong {
    font-weight: var(--f-weight-bold);
  }

  /* White CTA — 22.4/1920 = 1.17vw */
  .sp__panel .cta-btn--white {
    align-self: center;
    margin-top: 0.52vw;
    padding: 1.36vw 2.45vw;
    font-size: 1.17vw;
    border-radius: 18.7px;
  }

  /*
   * Right side group — single SVG with badge + connector + map
   * From Figma at 1920×1080: x=1236, y=201
   * SVG viewBox: 572×406
   */
  .sp__right-group {
    position: absolute;
    left: 70%;                     /* nudged right */
    top: 18.61%;                   /* 201/1080 */
    width: 29.79vw;                /* 572/1920 */
    z-index: 3;
    pointer-events: none;
  }

  .sp__right-svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ---- Responsive ---- */

  /* Medium desktop: ≤1440 */
  @media (max-width: 1440px) {
    .sp__panel {
      left: 5%;                        /* 72/1440 */
      width: 36.1vw;                   /* 520/1440 */
      padding: 3.33vw 2.5vw 2.5vw;
      gap: 1.25vw;
    }
    .sp__title { font-size: 1.8vw; }
    .sp__body { font-size: 1.32vw; }
    .sp__detail { font-size: 0.9vw; }
    .sp__panel .cta-btn--white {
      padding: 1.2vw 2.2vw;
      font-size: 1.1vw;
    }
    .sp__right-group {
      left: 59.03%;                    /* 850/1440 */
      top: 16.67%;                     /* 180/1080 */
      width: 35vw;
    }
  }

  /* Small desktop: ≤1280 */
  @media (max-width: 1280px) {
    .sp__panel {
      left: 5%;
      width: 35.9vw;
      padding: 2.8vw 2.34vw 2.34vw;
      gap: 1.09vw;
    }
    .sp__title { font-size: 1.72vw; }
    .sp__body { font-size: 1.25vw; }
    .sp__detail { font-size: 0.94vw; }
    .sp__panel .cta-btn--white {
      padding: 1vw 2vw;
      font-size: 1vw;
    }
    .sp__right-group {
      left: 54.69%;                    /* 700/1280 */
      top: 15.74%;                     /* 170/1080 */
      width: 38vw;
    }
  }

  /* Tablet: ≤768px — hide right group, panel full width */
  @media (max-width: 768px) {
    .sp__panel {
      left: 16px;
      right: 16px;
      width: auto;
      min-width: unset;
      top: 25%;
      padding: 24px 20px;
      gap: 12px;
    }
    .sp__title { font-size: 18px; }
    .sp__body { font-size: 14px; }
    .sp__detail { font-size: 13px; gap: 8px; }
    .sp__panel .cta-btn--white { padding: 18px 28px; font-size: 14px; }
    .sp__right-group { display: none; }
  }
</style>
