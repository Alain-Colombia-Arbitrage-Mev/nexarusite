---
---

<section class="section" id="section-strategic" data-section="strategic" data-video="/videos/Secuencia 003.mp4">
  <video class="section__video" muted playsinline preload="none"></video>

  <div class="gradient-left-teal"></div>
  <div class="gradient-top"></div>
  <div class="gradient-bottom"></div>

  <div class="sp__panel anim-fade-left">
    <h2 class="sp__title">
      A country built for global mobility, investment, and long-term security
    </h2>

    <div class="sp__body">
      <p>
        <strong>The United Arab Emirates</strong> offers a unique combination of legal certainty, financial infrastructure, and international connectivity. Its regulatory framework supports global entrepreneurs, investors, and professionals seeking operational stability and expansion.
      </p>
    </div>

    <div class="sp__detail">
      <p>
        <strong>With direct access to global markets,</strong> modern banking systems, and a secure legal environment, the UAE enables individuals and companies to establish a future aligned with international growth.
      </p>
      <p>
        <strong>Nexaru Global Services</strong> ensures this transition is structured, compliant, and professionally managed from initial assessment to full operational readiness.
      </p>
    </div>

    <button class="cta-btn--white cta-btn anim-fade-up">
      Explore Your Pathway
    </button>
  </div>

  <div class="sp__badge anim-fade-right">
    <div class="section-icon__circle" style="width:100px;height:100px;">
      <svg width="50" height="50" viewBox="0 0 50 50" fill="none"><path d="M11.68 9.35c1.08 0 2.14.32 3.04.93.9.6 1.6 1.46 2.01 2.46.41 1 .51 2.1.29 3.16-.22 1.06-.75 2.03-1.52 2.79h.86c.62 0 1.21.25 1.65.69.44.44.69 1.03.69 1.65s-.25 1.21-.69 1.65c-.44.44-1.03.69-1.65.69h-.58c.59 2.79 2.33 4.67 3.33 5.54.65.57 1.14 1.43 1.14 2.42 0 .39-.08.77-.22 1.13-.15.36-.37.68-.64.95-.27.27-.6.49-.96.64-.36.15-.74.22-1.13.22H6.06c-.39 0-.77-.08-1.13-.22-.36-.15-.68-.37-.95-.64-.27-.27-.49-.6-.64-.96-.15-.36-.22-.74-.22-1.13 0-.99.49-1.85 1.14-2.42 1-.88 2.74-2.75 3.33-5.54h-.58c-.62 0-1.21-.25-1.65-.69-.44-.44-.69-1.03-.69-1.65s.25-1.21.69-1.65c.44-.44 1.03-.69 1.65-.69h.86c-.77-.76-1.3-1.73-1.52-2.79-.22-1.06-.12-2.16.29-3.16.41-1 1.11-1.86 2.01-2.46.9-.6 1.96-.93 3.04-.93zM20.25 3.12c.41 0 .81.16 1.1.46.29.29.46.69.46 1.1v1.95c0 .31.12.61.34.83.22.22.52.34.83.34.31 0 .61-.12.83-.34.22-.22.34-.52.34-.83V4.68c0-.41.16-.81.46-1.1.29-.29.69-.46 1.1-.46.41 0 .81.16 1.1.46.29.29.46.69.46 1.1v1.95c0 .31.12.61.34.83.22.22.52.34.83.34.31 0 .61-.12.83-.34.22-.22.34-.52.34-.83V4.68c0-.41.16-.81.46-1.1.29-.29.69-.46 1.1-.46h.39c.31 0 .61.12.83.34.22.22.34.52.34.83v6.62c0 .83-.33 1.62-.91 2.2-.58.58-1.38.91-2.2.91h-.34c.41 8.5 3.37 13.59 4.4 15.13.37.55.62 1.22.62 1.94 0 1.76-1.42 3.18-3.18 3.18H20.7c.69-.79 1.1-1.82 1.1-2.94 0-1.52-.75-2.78-1.67-3.59-.36-.32-.7-.66-1.01-1.04 1.24-2.57 2.74-6.82 3.02-12.68h-.34c-.83 0-1.62-.33-2.2-.91-.58-.58-.91-1.38-.91-2.2V4.28c0-.31.12-.61.34-.83.22-.22.52-.34.83-.34h.39z" fill="#D5D5D5"/></svg>
    </div>
    <div class="sp__badge-label">
      <span>STRATEGIC</span>
      <span>POSITIONING</span>
    </div>
  </div>

  <!-- L-shaped connector from badge — Vector map.svg -->
  <div class="sp__connector anim-fade-right">
    <svg width="108" height="339" viewBox="0 0 108 339" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M101.833 335.887C101.833 337.359 103.027 338.553 104.5 338.553C105.973 338.553 107.167 337.359 107.167 335.887C107.167 334.414 105.973 333.22 104.5 333.22C103.027 333.22 101.833 334.414 101.833 335.887ZM5 2.38675L0 -2.14577e-06V5.7735L5 3.38675V2.38675ZM104.5 335.887H105V8.88675H104.5H104V335.887H104.5ZM98.5 2.88675V2.38675H4.5V2.88675V3.38675H98.5V2.88675ZM104.5 8.88675H105C105 5.29689 102.09 2.38675 98.5 2.38675V2.88675V3.38675C101.538 3.38675 104 5.84918 104 8.88675H104.5Z" fill="white"/>
    </svg>
  </div>

  <!-- UAE map outline — Vectormapa.svg -->
  <div class="sp__map-outline anim-fade-right">
    <svg width="271" height="100" viewBox="0 0 271 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1.0736 85.1463L39.1046 3.95647C40.5357 0.901242 44.2037 -0.373765 47.2213 1.13505L87.6768 21.3628C88.363 21.7059 89.1087 21.9142 89.8734 21.9765L131.716 25.3822H166.216H202.216L264.016 22.4393C268.901 22.2067 271.998 27.6021 269.333 31.7025L263.619 40.4918C263.028 41.4017 262.201 42.1342 261.226 42.6112L239.216 53.3822L162.205 98.0188C161.232 98.583 160.119 98.8622 158.995 98.8243L6.30532 93.688C2.00143 93.5432 -0.7531 89.046 1.0736 85.1463Z" fill="#D9D9D9" fill-opacity="0.2" stroke="white"/>
    </svg>
  </div>
</section>

<style>
  /* Left gradient — teal overlay matching Figma 857:346 */
  .gradient-left-teal {
    position: absolute;
    top: 0;
    left: 0;
    width: 51.25%;        /* 984/1920 */
    height: 100%;
    background: linear-gradient(
      to right,
      rgb(26, 58, 71) 0%,
      rgba(26, 58, 71, 0.5) 37.8%,
      rgba(26, 58, 71, 0) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* Glass card — Figma 857:349: 169px from left, centered vertically +25px */
  .sp__panel {
    position: absolute;
    left: 8.8%;                   /* 169/1920 */
    top: 50%;
    transform: translateY(calc(-50% + 2.3vh));
    width: 36.25vw;               /* 696/1920 */
    min-width: 360px;
    max-height: 82vh;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 1.3vh;
    padding: 3.7vh 2.45vw 2.8vh;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 18.7px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* Title — Figma 857:350: 32px at 1920x1080 → use min(vw, vh) */
  .sp__title {
    font-weight: var(--f-weight-bold);
    font-size: min(1.667vw, 2.96vh);   /* 32/1920, 32/1080 */
    color: #e0e0e0;
    text-transform: uppercase;
    line-height: 1.25;
  }

  /* Body — Figma 857:351: 24.6px at 1920x1080 */
  .sp__body {
    font-size: min(1.28vw, 2.28vh);    /* 24.6/1920, 24.6/1080 */
    line-height: 1.4;
    color: #e0e0e0;
  }

  .sp__body strong {
    font-weight: var(--f-weight-bold);
  }

  /* Detail — Figma 857:352: 15px at 1920x1080 */
  .sp__detail {
    font-size: min(0.78vw, 1.39vh);    /* 15/1920, 15/1080 */
    line-height: 1.55;
    color: #e0e0e0;
    display: flex;
    flex-direction: column;
    gap: 0.74vh;
  }

  .sp__detail strong {
    font-weight: var(--f-weight-bold);
  }

  /* White CTA — Figma 857:353: 22.4px */
  .sp__panel .cta-btn--white {
    align-self: center;
    margin-top: 0.56vh;
    padding: 2.4vh 2.45vw;
    font-size: min(1.17vw, 2.07vh);    /* 22.4/1920, 22.4/1080 */
    border-radius: 18.7px;
  }

  /* Badge — Figma 857:355: right=393/1920, top=201/1080 */
  .sp__badge {
    position: absolute;
    right: 20.47%;          /* 393/1920 */
    top: 18.61%;            /* 201/1080 */
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .sp__badge .section-icon__circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 3px solid #d5d5d5;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    flex-shrink: 0;
  }

  .sp__badge-label {
    display: flex;
    flex-direction: column;
    font-weight: var(--f-weight-medium);
    font-size: 1.5rem;
    color: #d5d5d5;
    white-space: nowrap;
    text-shadow:
      0 0 8px rgba(0, 0, 0, 0.9),
      0 0 20px rgba(0, 0, 0, 0.7),
      0 1px 3px rgba(0, 0, 0, 0.8);
  }

  /* L-shaped connector — Figma 857:357: left=1540/1920, top=240/1080 */
  .sp__connector {
    position: absolute;
    left: 80.21%;             /* 1540.5/1920 */
    top: 22.22%;              /* 240/1080 */
    z-index: 3;
    pointer-events: none;
    opacity: 0.6;
  }

  .sp__connector svg {
    display: block;
    width: 5.625vw;           /* 108/1920 */
    height: auto;
  }

  /* UAE map outline — Figma 857:356: left=1529/1920, top=506/1080 */
  .sp__map-outline {
    position: absolute;
    left: 79.64%;             /* 1529/1920 */
    top: 46.85%;              /* 506/1080 */
    z-index: 2;
    pointer-events: none;
    opacity: 0.7;
  }

  .sp__map-outline svg {
    width: 14.51vw;           /* 278.5/1920 */
    height: auto;
  }

  /* ---- Responsive ---- */

  /* Tablet and below — stack layout */
  @media (max-width: 1024px) {
    .sp__panel {
      left: 5%;
      right: 5%;
      width: auto;
      min-width: unset;
      max-height: none;
      transform: translateY(-50%);
      padding: 32px 28px;
      gap: 14px;
    }
    .sp__title { font-size: 22px; }
    .sp__body { font-size: 16px; }
    .sp__detail { font-size: 13px; }
    .sp__panel .cta-btn--white { padding: 20px 36px; font-size: 16px; }
    .sp__badge { display: none; }
    .sp__connector { display: none; }
    .sp__map-outline { display: none; }
  }

  @media (max-width: 768px) {
    .sp__panel {
      left: 16px;
      right: 16px;
      padding: 24px 20px;
      gap: 12px;
    }
    .sp__title { font-size: 18px; }
    .sp__body { font-size: 14px; }
    .sp__detail { font-size: 12px; }
    .sp__panel .cta-btn--white { padding: 18px 28px; font-size: 14px; }
  }
</style>
