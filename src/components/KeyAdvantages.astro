---
const advantages = [
  { title: 'Global Market Access', desc: 'Operate from a jurisdiction connecting Europe, Asia, and Africa within hours.', icon: 'G' },
  { title: 'Tax Efficiency', desc: 'Access competitive corporate structures and zero personal income tax.', icon: 'T' },
  { title: 'Legal and Political Stability', desc: 'Benefit from a secure and internationally recognized legal framework.', icon: 'L' },
  { title: 'Operational Freedom', desc: 'Establish and manage companies with flexible ownership structures.', icon: 'O' },
  { title: 'Financial Infrastructure', desc: "Operate within one of the world's most advanced banking environments.", icon: 'F' },
  { title: 'Personal and Family Security', desc: 'Live and operate in one of the safest countries globally.', icon: 'P' },
];
---

<section class="section" id="section-advantages" data-section="advantages" data-video="/videos/Secuencia 005.mp4">
  <video class="section__video" muted playsinline preload="none"></video>

  <div class="ka__gradient-left"></div>
  <div class="gradient-top"></div>
  <div class="gradient-bottom"></div>

  <div class="ka__content">
    <div class="ka__header">
      <h2 class="ka__headline anim-fade-left">
        Why global founders, investors,
      </h2>
      <p class="ka__subheadline anim-fade-left">
        and professionals choose the UAE
      </p>
    </div>

    <div class="ka__grid">
      {advantages.map((item, i) => (
        <div class="ka__card anim-scale-in" style={`--delay: ${i * 0.08}s`}>
          <div class="ka__card-icon">
            <div class="ka__card-icon-placeholder">{item.icon}</div>
          </div>
          <div class="ka__card-text">
            <p class="ka__card-title">{item.title}</p>
            <p class="ka__card-desc">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="ka__cta anim-fade-up">
      <button class="cta-btn--lg cta-btn">
        Start Your UAE Establishment
      </button>
    </div>
  </div>
</section>

<style>
  /* Remove backdrop-filter flickering */
  #section-advantages .gradient-top,
  #section-advantages .gradient-bottom {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* Left gradient — wider than Strategic Positioning */
  .ka__gradient-left {
    position: absolute;
    top: 0;
    left: 0;
    width: 67.86%;                   /* 1303/1920 */
    height: 100%;
    background: linear-gradient(
      to right,
      rgb(8, 29, 37) 0%,
      rgba(8, 29, 37, 0.5) 37.8%,
      rgba(8, 29, 37, 0) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* Content layout — centered vertically */
  .ka__content {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 0 0 6.61%;            /* left=127/1920 */
    gap: 1.5vh;
  }

  /* Headline — scales with viewport */
  .ka__headline {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-extrabold);
    font-size: clamp(28px, 5.5vh, 70px);
    color: #e6e6e6;
    text-transform: uppercase;
    line-height: 1.02;
  }

  /* Subheadline */
  .ka__subheadline {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-regular);
    font-size: clamp(18px, 3.2vh, 40px);
    color: #e6e6e6;
    line-height: 1.2;
  }

  .ka__header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* Card grid — 2 columns */
  .ka__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1vh 3.49vw;                /* row gap scales with height */
    max-width: 50.42vw;             /* 968/1920 */
  }

  /* Card — scales with both vw and vh */
  .ka__card {
    display: flex;
    align-items: center;
    gap: 1.13vw;                     /* 22/1920 */
    background: var(--glass-bg);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: var(--glass-radius);
    border: var(--glass-border);
    padding: 1.2vh 1.41vw;
    width: 22.9vw;                   /* 440/1920 */
    min-height: 11vh;                /* scales with viewport height */
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.4s ease,
                border-color 0.4s ease,
                background 0.4s ease;
    transform-style: preserve-3d;
    cursor: pointer;
  }

  .ka__card:hover {
    transform: translateY(-4px) scale(1.02) perspective(800px) rotateX(2deg);
    background: rgba(0, 0, 0, 0.45);
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 0 40px rgba(80, 180, 220, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .ka__card:hover .ka__card-icon {
    border-color: #ffffff;
    box-shadow: 0 0 20px rgba(80, 180, 220, 0.2);
  }

  .ka__card:hover .ka__card-title {
    color: #ffffff;
  }

  .ka__card-icon {
    width: clamp(44px, 4.71vw, 90px);
    height: clamp(44px, 4.71vw, 90px);
    min-width: 44px;
    min-height: 44px;
    border-radius: 50%;
    border: 2.7px solid #d5d5d5;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .ka__card-icon-placeholder {
    font-size: 1.3vw;
    color: #d5d5d5;
    font-weight: var(--f-weight-bold);
  }

  .ka__card-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.38vw;                     /* 7/1920 */
    flex: 1;
  }

  /* Card title */
  .ka__card-title {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-semibold);
    font-size: clamp(14px, 1.13vw, 22px);
    color: #d5d5d5;
    transition: color 0.4s ease;
  }

  /* Card desc */
  .ka__card-desc {
    font-family: var(--f-primary);
    font-weight: var(--f-weight-regular);
    font-size: clamp(11px, 0.75vw, 14.5px);
    color: #e9e9e9;
    line-height: 1.4;
  }

  /* CTA — below grid */
  .ka__cta {
    margin-top: 1.5vh;
    align-self: flex-start;
    padding-left: 3%;
  }

  .ka__cta .cta-btn--lg.cta-btn {
    padding: 18px 50px;
    font-size: 1rem;
    border-radius: 16px;
  }

  /* ---- Responsive ---- */

  /* Medium desktop: ≤1440 */
  @media (max-width: 1440px) {
    .ka__content {
      padding: 15% 0 0 5%;
    }
    .ka__grid {
      max-width: 55vw;
    }
  }

  /* Small desktop: ≤1280 */
  @media (max-width: 1280px) {
    .ka__content {
      padding: 14% 0 0 5%;
      gap: 1.5vw;
    }
    .ka__grid {
      max-width: 60vw;
      gap: 1vw 3vw;
    }
    .ka__card {
      width: 28vw;
    }
  }

  /* Tablet landscape: ≤1024 */
  @media (max-width: 1024px) {
    .ka__content {
      padding: 12% 5% 0;
      gap: 1.5vw;
    }
    .ka__headline { font-size: 4.5vw; }
    .ka__subheadline { font-size: 2.5vw; }
    .ka__grid {
      max-width: 90vw;
      gap: 1.2vw 2.5vw;
    }
    .ka__card {
      width: 43vw;
      min-height: 9vw;
      padding: 1.2vw 1.8vw;
    }
    .ka__card-title { font-size: 1.5vw; }
    .ka__card-desc { font-size: 1vw; }
    .ka__card-icon {
      width: 6vw;
      height: 6vw;
    }
    .ka__cta { padding-left: 0; }
  }

  /* Tablet portrait: ≤768px */
  @media (max-width: 768px) {
    .ka__gradient-left { width: 100%; }
    .ka__content {
      padding: 100px 20px 80px;
      gap: 16px;
      justify-content: center;
    }
    .ka__headline { font-size: 28px; }
    .ka__subheadline { font-size: 18px; }
    .ka__grid {
      flex-direction: column;
      max-width: 100%;
      gap: 12px;
    }
    .ka__card {
      width: 100%;
      min-height: auto;
      padding: 14px 18px;
      gap: 14px;
      border-radius: 14px;
    }
    .ka__card-icon {
      width: 56px;
      height: 56px;
      min-width: 56px;
      min-height: 56px;
    }
    .ka__card-icon-placeholder { font-size: 18px; }
    .ka__card-title { font-size: 16px; }
    .ka__card-desc { font-size: 13px; }
    .ka__cta {
      align-self: center;
      padding-left: 0;
      padding-bottom: 0;
    }
    .ka__cta .cta-btn {
      padding: 20px 30px;
      font-size: 14px;
    }
  }

  /* Mobile: ≤480px */
  @media (max-width: 480px) {
    .ka__content {
      padding: 80px 12px 60px;
      gap: 12px;
    }
    .ka__headline { font-size: 22px; }
    .ka__subheadline { font-size: 15px; }
    .ka__card {
      padding: 12px 14px;
      gap: 12px;
    }
    .ka__card-icon {
      width: 48px;
      height: 48px;
      min-width: 48px;
      min-height: 48px;
    }
    .ka__card-title { font-size: 14px; }
    .ka__card-desc { font-size: 12px; }
    .ka__cta .cta-btn {
      padding: 16px 24px;
      font-size: 13px;
    }
  }
</style>
